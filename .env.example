# ── Spotify OAuth (one shared app, registered in the Spotify Developer Dashboard) ──
# The client secret is confidential and must NEVER reach the browser.
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# Must byte-match a redirect URI registered on the Spotify app.
#   prod:  https://spotify.caes.ar/api/auth/callback
#   local: http://127.0.0.1:3000/api/auth/callback   (loopback IP, NOT "localhost")
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback
# Minimum scope for the now-playing widget.
SPOTIFY_SCOPES=user-read-currently-playing

# ── App crypto ──
# HS256 signing key for session + oauth-state cookies. openssl rand -base64 32
SESSION_SECRET=change-me-openssl-rand-base64-32
# AES-256-GCM key (32 bytes, base64) for encrypting Spotify refresh tokens at rest.
# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=change-me-openssl-rand-base64-32

# ── Public base URL (used to build the copyable overlay URL) ──
BASE_URL=http://127.0.0.1:3000

# ── Database (CloudNativePG in prod; local Postgres in dev) ──
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=spotify_widget
DATABASE_USER=spotify_user
DATABASE_PASSWORD=dev
# Optional: a single DSN overrides the discrete DATABASE_* vars above.
# DATABASE_URL=postgresql://spotify_user:dev@127.0.0.1:5432/spotify_widget

# ── Runtime ──
LOG_LEVEL=info
PORT=3000

# ── Test-only overrides (point the Spotify client at a local stub) ──
# SPOTIFY_ACCOUNTS_BASE=https://accounts.spotify.com
# SPOTIFY_API_BASE=https://api.spotify.com/v1
